<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@color/keyboard_bg">

    <!-- 彈出面板容器（剪貼簿/常用指令），預設隱藏 -->
    <FrameLayout
        android:id="@+id/panelContainer"
        android:layout_width="match_parent"
        android:layout_height="220dp"
        android:visibility="gone"
        android:background="#0d0d1a" />

    <!-- 狀態列（錄音時才顯示） -->
    <TextView
        android:id="@+id/statusText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text=""
        android:textColor="@color/status_text"
        android:textSize="11sp"
        android:gravity="center"
        android:paddingTop="2dp"
        android:paddingBottom="1dp"
        android:visibility="gone" />

    <!-- 預覽文字 -->
    <TextView
        android:id="@+id/previewText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text=""
        android:textColor="@color/key_text"
        android:textSize="14sp"
        android:gravity="center"
        android:visibility="gone" />

    <!-- ========== 語音鍵盤（預設顯示） ========== -->
    <LinearLayout
        android:id="@+id/voiceKeyboard"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingStart="2dp"
        android:paddingEnd="2dp"
        android:paddingBottom="2dp">

        <!-- 左側：功能列 + 編輯列 -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="3"
            android:orientation="vertical">

            <!-- Row 1：功能列 — 🔄 ⚙ 📋 ⚡ 追 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="38dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="2dp">

                <TextView
                    android:id="@+id/btnSwitchIME"
                    android:layout_width="0dp"
                    android:layout_height="34dp"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:text="EN"
                    android:textSize="12sp"
                    android:textColor="#6bc5f0"
                    android:background="@color/key_bg"
                    android:layout_marginEnd="2dp"
                    android:clickable="true"
                    android:focusable="true" />

                <TextView
                    android:id="@+id/btnSettings"
                    android:layout_width="0dp"
                    android:layout_height="34dp"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:text="⚙"
                    android:textSize="14sp"
                    android:textColor="#666666"
                    android:background="@color/key_bg"
                    android:layout_marginEnd="2dp"
                    android:clickable="true"
                    android:focusable="true" />

                <TextView
                    android:id="@+id/btnClipboard"
                    android:layout_width="0dp"
                    android:layout_height="34dp"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:text="📋"
                    android:textSize="14sp"
                    android:textColor="#666666"
                    android:background="@color/key_bg"
                    android:layout_marginEnd="2dp"
                    android:clickable="true"
                    android:focusable="true" />

                <TextView
                    android:id="@+id/btnCommands"
                    android:layout_width="0dp"
                    android:layout_height="34dp"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:text="⚡"
                    android:textSize="14sp"
                    android:textColor="#666666"
                    android:background="@color/key_bg"
                    android:layout_marginEnd="2dp"
                    android:clickable="true"
                    android:focusable="true" />

                <TextView
                    android:id="@+id/btnMode"
                    android:layout_width="0dp"
                    android:layout_height="34dp"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:text="追"
                    android:textColor="@color/mode_append"
                    android:textSize="14sp"
                    android:background="@color/key_bg"
                    android:clickable="true"
                    android:focusable="true" />

            </LinearLayout>

            <!-- Row 2：編輯列 — ␣ ， 。 ⌫ ↵ -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="42dp"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:id="@+id/btnSpace"
                    android:layout_width="0dp"
                    android:layout_height="38dp"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:text="␣"
                    android:textColor="@color/key_text"
                    android:textSize="16sp"
                    android:background="@color/key_bg"
                    android:layout_marginEnd="2dp"
                    android:clickable="true"
                    android:focusable="true" />

                <TextView
                    android:id="@+id/btnComma"
                    android:layout_width="0dp"
                    android:layout_height="38dp"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:text="，"
                    android:textColor="@color/key_text"
                    android:textSize="16sp"
                    android:background="@color/key_bg"
                    android:layout_marginEnd="2dp"
                    android:clickable="true"
                    android:focusable="true" />

                <TextView
                    android:id="@+id/btnPeriod"
                    android:layout_width="0dp"
                    android:layout_height="38dp"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:text="。"
                    android:textColor="@color/key_text"
                    android:textSize="16sp"
                    android:background="@color/key_bg"
                    android:layout_marginEnd="2dp"
                    android:clickable="true"
                    android:focusable="true" />

                <TextView
                    android:id="@+id/btnBackspace"
                    android:layout_width="0dp"
                    android:layout_height="38dp"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:text="⌫"
                    android:textSize="16sp"
                    android:textColor="@color/key_text"
                    android:background="@color/key_bg"
                    android:layout_marginEnd="2dp"
                    android:clickable="true"
                    android:focusable="true" />

                <TextView
                    android:id="@+id/btnEnter"
                    android:layout_width="0dp"
                    android:layout_height="38dp"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:text="↵"
                    android:textSize="16sp"
                    android:textColor="#8fbc8f"
                    android:background="#1b3326"
                    android:clickable="true"
                    android:focusable="true" />

            </LinearLayout>

        </LinearLayout>

        <!-- 右側：大麥克風按鈕（跨兩列） -->
        <Button
            android:id="@+id/btnMic"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:layout_marginStart="2dp"
            android:text="🎤"
            android:textSize="28sp"
            android:textColor="@color/key_text"
            android:background="@color/mic_idle" />

    </LinearLayout>

    <!-- ========== 英文鍵盤（預設隱藏） ========== -->
    <include
        layout="@layout/keyboard_english"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:visibility="gone" />

    <!-- ========== 數字符號鍵盤（預設隱藏） ========== -->
    <include
        layout="@layout/keyboard_numbers"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:visibility="gone" />

</LinearLayout>
