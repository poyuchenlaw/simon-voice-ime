<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#1a1a2e">

    <!-- 標題列 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="16dp">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="⚡ 常用指令編輯器"
            android:textSize="20sp"
            android:textColor="#e0e0e0" />

        <Button
            android:id="@+id/btnAddGroup"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:text="＋群組"
            android:textSize="12sp"
            android:textColor="#4ecca3"
            android:paddingStart="12dp"
            android:paddingEnd="12dp" />
    </LinearLayout>

    <!-- 群組 Tab -->
    <HorizontalScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:scrollbars="none"
        android:paddingStart="12dp"
        android:paddingEnd="12dp">

        <LinearLayout
            android:id="@+id/editorGroupTabs"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingBottom="8dp" />
    </HorizontalScrollView>

    <!-- 群組操作列 -->
    <LinearLayout
        android:id="@+id/groupActionsRow"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingBottom="8dp">

        <Button
            android:id="@+id/btnRenameGroup"
            android:layout_width="wrap_content"
            android:layout_height="32dp"
            android:text="改名"
            android:textSize="11sp"
            android:textColor="#f0a500"
            android:paddingStart="10dp"
            android:paddingEnd="10dp"
            android:layout_marginEnd="8dp" />

        <Button
            android:id="@+id/btnDeleteGroup"
            android:layout_width="wrap_content"
            android:layout_height="32dp"
            android:text="刪除群組"
            android:textSize="11sp"
            android:textColor="#e94560"
            android:paddingStart="10dp"
            android:paddingEnd="10dp" />

        <View
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_weight="1" />

        <Button
            android:id="@+id/btnAddCommand"
            android:layout_width="wrap_content"
            android:layout_height="32dp"
            android:text="＋指令"
            android:textSize="11sp"
            android:textColor="#4ecca3"
            android:paddingStart="10dp"
            android:paddingEnd="10dp" />
    </LinearLayout>

    <!-- 指令列表 -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/editorCmdRecycler"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:padding="8dp" />

</LinearLayout>
